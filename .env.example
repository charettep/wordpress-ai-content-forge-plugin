# AI Content Forge local environment template
#
# Copy this file to `.env` only if you want to preseed values manually.
# In normal local development, `./scripts/docker-setup.sh` will create `.env`,
# keep it chmod 600, preserve existing values, and generate secure random
# database/admin secrets for blank fields.
#
# `.env` is intentionally gitignored and must stay local to your machine.

# Local Docker WordPress instance
SITE_PORT=8080
PMA_PORT=8081

MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

WORDPRESS_DB_HOST=db
WORDPRESS_DB_NAME=
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=

PMA_HOST=db
PMA_USER=
PMA_PASSWORD=

WP_ADMIN_USERNAME=admin
WP_ADMIN_PASSWORD=
WP_ADMIN_EMAIL=admin@example.test
WP_SITE_TITLE=AI Content Forge Development
WP_BLOG_DESCRIPTION=WordPress development environment

OLLAMA_PROXY_PORT=11435
OLLAMA_HOST_TARGET=127.0.0.1:11434

# Cloudflare + Ollama remote access wizard
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_NAME=home-ollama
CLOUDFLARE_TUNNEL_DOMAIN=
CLOUDFLARE_OLLAMA_SUBDOMAIN=ollama
CLOUDFLARE_ACCESS_APP_NAME=Ollama API
CLOUDFLARE_SERVICE_TOKEN_NAME=ai-content-forge-ollama
CLOUDFLARE_SERVICE_TOKEN_DURATION=8760h
CLOUDFLARE_ACCESS_HEADER_NAME=Authorization
OLLAMA_LOCAL_URL=http://localhost:11434
